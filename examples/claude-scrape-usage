#!/usr/bin/env python3
"""
claude-scrape-usage - Scrape usage from Claude Desktop UI

Uses UI automation to open Settings → Usage and extract both
current session and weekly limit percentages.

Requirements:
    sudo pacman -S xdotool scrot tesseract
    # OR
    sudo apt install xdotool scrot tesseract-ocr

Author: Uncle Tallest & Vector
Created: 2026-03-25
"""

import os
import sys
import time
import subprocess
import re
from pathlib import Path
from PIL import Image
import pytesseract


def check_dependencies():
    """Check if required tools are installed"""
    tools = {
        'xdotool': 'xdotool',
        'scrot': 'scrot', 
        'tesseract': 'tesseract-ocr'
    }
    
    missing = []
    for cmd, package in tools.items():
        try:
            subprocess.run([cmd, '--version'], 
                          capture_output=True, check=True)
        except (subprocess.CalledProcessError, FileNotFoundError):
            missing.append(package)
    
    if missing:
        print(f"ERROR: Missing dependencies: {', '.join(missing)}", file=sys.stderr)
        print("\nInstall with:")
        print(f"  sudo pacman -S {' '.join(missing)}  # Arch/Manjaro")
        print(f"  # OR")
        print(f"  sudo apt install {' '.join(missing)}  # Ubuntu/Debian")
        return False
    
    return True


def find_claude_window():
    """Find Claude Desktop window ID"""
    try:
        result = subprocess.run(
            ['xdotool', 'search', '--name', 'Claude'],
            capture_output=True, text=True, check=True
        )
        windows = result.stdout.strip().split('\n')
        return windows[0] if windows else None
    except subprocess.CalledProcessError:
        return None


def activate_window(window_id):
    """Activate and focus a window"""
    subprocess.run(['xdotool', 'windowactivate', window_id])
    time.sleep(0.5)


def send_keys(keys):
    """Send keyboard input"""
    subprocess.run(['xdotool', 'key', keys])
    time.sleep(0.3)


def screenshot_region(x, y, width, height, output_path):
    """Take screenshot of specific region"""
    subprocess.run([
        'scrot', '-a', f'{x},{y},{width},{height}', 
        str(output_path)
    ])


def extract_percentage_from_image(image_path):
    """Use OCR to extract percentage from image"""
    try:
        img = Image.open(image_path)
        text = pytesseract.image_to_string(img)
        
        # Look for percentage patterns: "31% used", "59% used", etc.
        matches = re.findall(r'(\d+)%', text)
        return [int(m) for m in matches]
    
    except Exception as e:
        print(f"OCR error: {e}", file=sys.stderr)
        return []


def scrape_usage():
    """Scrape usage from Claude Desktop"""
    
    print("Scraping usage from Claude Desktop...")
    print("=" * 50)
    print()
    
    # Find Claude window
    window_id = find_claude_window()
    if not window_id:
        print("ERROR: Claude Desktop window not found", file=sys.stderr)
        print("Make sure Claude Desktop is running", file=sys.stderr)
        return None
    
    print(f"Found Claude window: {window_id}")
    
    # Activate window
    activate_window(window_id)
    
    # Navigate to Settings → Usage
    # Ctrl+, opens settings
    print("Opening Settings...")
    send_keys('ctrl+comma')
    time.sleep(1)
    
    # Click Usage in sidebar (or use arrow keys)
    print("Navigating to Usage tab...")
    # This is hacky - might need adjustment based on UI
    send_keys('Tab Tab Tab Tab Tab Tab Return')
    time.sleep(1)
    
    # Screenshot the usage area
    # You'll need to adjust these coordinates based on your screen
    print("Taking screenshot...")
    screenshot_path = Path('/tmp/claude-usage-screenshot.png')
    
    # Rough coordinates - adjust based on your setup
    # This captures roughly where the usage percentages appear
    screenshot_region(800, 300, 400, 400, screenshot_path)
    
    # OCR the screenshot
    print("Extracting percentages...")
    percentages = extract_percentage_from_image(screenshot_path)
    
    # Close settings
    send_keys('Escape')
    
    if len(percentages) >= 2:
        print()
        print(f"Current session: {percentages[0]}%")
        print(f"Weekly limit: {percentages[1]}%")
        return {
            'current_session': percentages[0],
            'weekly': percentages[1]
        }
    else:
        print("ERROR: Could not extract usage percentages", file=sys.stderr)
        print(f"Found: {percentages}", file=sys.stderr)
        return None


def main():
    if not check_dependencies():
        return 1
    
    try:
        import pytesseract
    except ImportError:
        print("ERROR: pytesseract not installed", file=sys.stderr)
        print("Install with: pip install pytesseract --break-system-packages")
        return 1
    
    usage = scrape_usage()
    
    if usage:
        print()
        print("✓ Successfully scraped usage data!")
        print("  You can now update headroom with these values")
        return 0
    
    return 1


if __name__ == '__main__':
    sys.exit(main())
