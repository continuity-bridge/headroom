#!/usr/bin/env python3
"""
claude-sync-usage - Manually sync usage from Claude Desktop

When you check Settings → Usage in Claude Desktop, run this to update headroom.

Usage:
    claude-sync-usage 31 59              # Current session 31%, Weekly 59%
    claude-sync-usage 31 59 55m          # + session resets in 55 minutes
    claude-sync-usage 31 59 55m "Fri 2PM" # + weekly resets Fri 2PM
    claude-sync-usage --session 31       # Update only current session
    claude-sync-usage --weekly 59        # Update only weekly limit

Author: Uncle Tallest & Vector
Created: 2026-03-25
"""

import os
import sys
import json
from pathlib import Path
from datetime import datetime


def detect_instance_home():
    """Detect INSTANCE_HOME directory"""
    if env_home := os.getenv('INSTANCE_HOME'):
        return Path(env_home)
    if env_home := os.getenv('CLAUDE_HOME'):
        return Path(env_home)
    
    candidates = [
        Path.home() / "Substrate",
        Path.home() / "Claude",
        Path.home() / "continuity-bridge_tallest-anchor"
    ]
    
    for candidate in candidates:
        if candidate.exists():
            return candidate
    
    return None


def sync_usage(session_percent=None, weekly_percent=None, session_reset=None, weekly_reset=None):
    """Sync usage from Claude Desktop to local tracking"""
    
    instance_home = detect_instance_home()
    if not instance_home:
        print("ERROR: Cannot locate INSTANCE_HOME", file=sys.stderr)
        return 1
    
    state_file = instance_home / '.claude' / 'logs' / 'limit-tracker-state.json'
    
    # Load or create state
    if state_file.exists():
        with open(state_file) as f:
            state = json.load(f)
    else:
        state = {
            'plan': 'pro',
            'window_hours': 5,
            'events': [],
            'weekly_usage': None
        }
    
    # Update current session
    if session_percent is not None:
        limit = 45  # Pro plan 5-hour window limit
        calculated_used = (session_percent / 100) * limit
        
        # Clear old events and add a sync marker
        state['events'] = [{
            'timestamp': datetime.now().isoformat(),
            'product': 'chat',
            'weight': calculated_used,
            'source': 'manual_sync_from_claude_desktop'
        }]
        
        print(f"✓ Current session: {calculated_used:.1f}/{limit} units ({session_percent}%)")
        if session_reset:
            state['session_reset'] = session_reset
            print(f"  Resets in: {session_reset}")
    
    # Update weekly usage
    if weekly_percent is not None:
        state['weekly_usage'] = {
            'percent': weekly_percent,
            'timestamp': datetime.now().isoformat(),
            'source': 'manual_sync_from_claude_desktop',
            'reset_time': weekly_reset
        }
        
        print(f"✓ Weekly usage: {weekly_percent}%")
        if weekly_reset:
            print(f"  Resets: {weekly_reset}")
    
    # Save
    state_file.parent.mkdir(parents=True, exist_ok=True)
    with open(state_file, 'w') as f:
        json.dump(state, f, indent=2)
    
    print(f"  headroom will now show this usage")
    
    return 0


def main():
    import os
    
    if len(sys.argv) < 2:
        print("Usage:")
        print("  claude-sync-usage 31 59           # Current session 31%, Weekly 59%")
        print("  claude-sync-usage --session 31    # Update only current session")
        print("  claude-sync-usage --weekly 59     # Update only weekly limit")
        print()
        print("Check Claude Desktop Settings → Usage, then run this")
        return 1
    
    session_percent = None
    weekly_percent = None
    session_reset = None
    weekly_reset = None
    
    # Check for positional args first (most common usage)
    if len(sys.argv) >= 3 and not sys.argv[1].startswith('--'):
        try:
            session_percent = float(sys.argv[1])
            weekly_percent = float(sys.argv[2])
            if len(sys.argv) >= 4:
                session_reset = sys.argv[3]
            if len(sys.argv) >= 5:
                weekly_reset = sys.argv[4]
            return sync_usage(session_percent, weekly_percent, session_reset, weekly_reset)
        except ValueError:
            pass  # Fall through to flag parsing
    
    # Parse arguments
    i = 1
    while i < len(sys.argv):
        arg = sys.argv[i]
        
        if arg in ['--session', '-s']:
            if i + 1 >= len(sys.argv):
                print("ERROR: --session requires a value", file=sys.stderr)
                return 1
            try:
                session_percent = float(sys.argv[i + 1])
                i += 2
            except ValueError:
                print("ERROR: Invalid session percentage", file=sys.stderr)
                return 1
        
        elif arg in ['--weekly', '-w']:
            if i + 1 >= len(sys.argv):
                print("ERROR: --weekly requires a value", file=sys.stderr)
                return 1
            try:
                weekly_percent = float(sys.argv[i + 1])
                i += 2
            except ValueError:
                print("ERROR: Invalid weekly percentage", file=sys.stderr)
                return 1
        
        else:
            # Positional arguments: session weekly
            try:
                session_percent = float(arg)
                if i + 1 < len(sys.argv):
                    weekly_percent = float(sys.argv[i + 1])
                    i += 2
                else:
                    i += 1
                break
            except ValueError:
                print(f"ERROR: Invalid argument: {arg}", file=sys.stderr)
                return 1
    
    if session_percent is None and weekly_percent is None:
        print("ERROR: Must provide at least one value to sync", file=sys.stderr)
        return 1
    
    return sync_usage(session_percent=session_percent, weekly_percent=weekly_percent)


if __name__ == '__main__':
    sys.exit(main())
